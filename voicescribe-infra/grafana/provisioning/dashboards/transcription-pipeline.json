{
  "uid": "voicescribe-transcription",
  "title": "VoiceScribe - Transcription Pipeline",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Inference Latency (s)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "voicescribe_inference_latency_seconds", "refId": "A"}],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "GPU Throughput (jobs/min)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(voicescribe_transcriptions_completed_total[1m]))", "refId": "A"}],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Celery Queue Depth",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by(queue)(celery_queue_depth)", "refId": "A"}],
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8}
    }
  ]
}
