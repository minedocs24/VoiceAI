{
  "uid": "voicescribe-free-tier",
  "title": "VoiceScribe - Free Tier Monitoring",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Free Tier Consumed Quota",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by(tenant_id)(voicescribe_free_tier_used_count)", "refId": "A"}],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Quota Exceeded Attempts",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(voicescribe_quota_exceeded_attempts_total[5m]))", "refId": "A"}],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Upgrade Attempts",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(voicescribe_upgrade_attempts_total[5m]))", "refId": "A"}],
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8}
    }
  ]
}
