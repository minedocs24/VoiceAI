# =========================
# Database (obbligatorie)
# =========================
# Host PostgreSQL interno Docker. Formato: hostname servizio compose.
# Obbligatoria. Default: postgres
POSTGRES_HOST=postgres
# Porta PostgreSQL interna. Formato: intero 1-65535.
# Obbligatoria. Default: 5432
POSTGRES_PORT=5432
# Nome database amministrativo usato dal container PostgreSQL.
# Obbligatoria. Default: postgres
POSTGRES_DB=postgres
# Utente amministrativo PostgreSQL iniziale.
# Obbligatoria.
POSTGRES_USER=postgres
# Password utente amministrativo PostgreSQL.
# Obbligatoria.
POSTGRES_PASSWORD=change_me_postgres_admin
# Nome database applicativo VoiceScribe.
# Obbligatoria. Default: voicescribe
VOICESCRIBE_DB_NAME=voicescribe
# Utente applicativo dedicato VoiceScribe.
# Obbligatoria.
VOICESCRIBE_DB_USER=voicescribe_app
# Password utente applicativo VoiceScribe.
# Obbligatoria.
VOICESCRIBE_DB_PASSWORD=change_me_voicescribe_app
# URL SQLAlchemy/Alembic completo.
# Opzionale se composti host/porta/user/password. Formato URI.
DATABASE_URL=postgresql+psycopg://voicescribe_app:change_me_voicescribe_app@postgres:5432/voicescribe

# =========================
# Redis (obbligatorie)
# =========================
# Password Redis richiesta per AUTH.
# Obbligatoria.
REDIS_PASSWORD=change_me_redis_password
# Host Redis interno Docker.
# Obbligatoria. Default: redis
REDIS_HOST=redis
# Porta Redis interna.
# Obbligatoria. Default: 6379
REDIS_PORT=6379

# =========================
# Networking / domini
# =========================
# Dominio pubblico principale.
# Obbligatoria in produzione, opzionale in locale.
VOICESCRIBE_DOMAIN=voicescribe.local
# Timezone infrastruttura. Formato TZ database.
# Opzionale. Default: UTC
TZ=UTC

# =========================
# Nginx / TLS
# =========================
# Percorso cert TLS nel container Nginx.
# Obbligatoria in prod.
NGINX_TLS_CERT=/etc/nginx/certs/voicescribe.crt
# Percorso private key TLS nel container Nginx.
# Obbligatoria in prod.
NGINX_TLS_KEY=/etc/nginx/certs/voicescribe.key
# Header X-Internal-Token per comunicazioni interne.
# Obbligatoria.
INTERNAL_SERVICE_TOKEN=change_me_internal_token

# JWT per Free Tier (api-gateway)
JWT_SECRET_KEY=change_me_jwt_secret

# HuggingFace token per diarization (SVC-07)
HUGGINGFACE_TOKEN=

# =========================
# Prometheus
# =========================
# Intervallo scrape globale. Formato durata Prometheus.
# Opzionale. Default: 15s
PROMETHEUS_SCRAPE_INTERVAL=15s
# Intervallo evaluation regole alert.
# Opzionale. Default: 15s
PROMETHEUS_EVALUATION_INTERVAL=15s

# =========================
# Grafana
# =========================
# Username admin Grafana.
# Obbligatoria.
GRAFANA_ADMIN_USER=admin
# Password admin Grafana.
# Obbligatoria.
GRAFANA_ADMIN_PASSWORD=change_me_grafana_admin
# URL pubblica Grafana.
# Opzionale.
GRAFANA_ROOT_URL=https://voicescribe.local/grafana/

# =========================
# Sistema / Ramdisk
# =========================
# Mount point ramdisk tmpfs.
# Obbligatoria. Default: /mnt/ramdisk
RAMDISK_PATH=/mnt/ramdisk
# Dimensione ramdisk tmpfs.
# Obbligatoria. Default: 32G
RAMDISK_SIZE=32G
# Percentuale soglia alert ramdisk.
# Obbligatoria. Default: 80
RAMDISK_ALERT_THRESHOLD_PCT=80
# Giorni retention backup DB locale.
# Opzionale. Default: 14
DB_BACKUP_RETENTION_DAYS=14
# Directory backup DB host.
# Opzionale. Default: ./backups
DB_BACKUP_DIR=./backups
