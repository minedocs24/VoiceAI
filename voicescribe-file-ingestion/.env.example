# Storage
STORAGE_BASE_PATH=/data/input
TEMP_UPLOAD_DIR=/tmp/voicescribe-upload
UPLOAD_MAX_BYTES=2147483648

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=3
REDIS_PASSWORD=change_me_redis_password
REDIS_TIMEOUT=5
PROBE_CACHE_TTL_SECONDS=3600

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://voicescribe_app:change_me_voicescribe_app@postgres:5432/voicescribe

# Inter-service
QUOTA_MANAGER_URL=http://voicescribe-quota-manager:8002
INTERNAL_SERVICE_TOKEN=change_me_internal_token

# Service
PORT=8001
LOG_LEVEL=INFO
PROBE_TIMEOUT_SECONDS=30
FREE_TIER_MAX_DURATION_SECONDS=1800
HEALTH_DISK_DEGRADED_THRESHOLD_PCT=80
TEMP_FILE_MAX_AGE_SECONDS=3600
TEMP_CLEANUP_INTERVAL_SECONDS=900
UPLOAD_CHUNK_SIZE=262144
MAGIC_BUFFER_SIZE=64