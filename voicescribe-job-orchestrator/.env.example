# Celery
CELERY_BROKER_URL=redis://:change_me_redis_password@redis:6379/0
CELERY_RESULT_BACKEND=redis://:change_me_redis_password@redis:6379/1

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://voicescribe_app:change_me_voicescribe_app@postgres:5432/voicescribe

# Downstream services
SVC02_URL=http://voicescribe-file-ingestion:8001
SVC03_URL=http://voicescribe-quota-manager:8002
SVC04_URL=http://voicescribe-audio-preprocessor:8003
SVC06_URL=http://voicescribe-transcription-engine:8005
SVC07_URL=http://voicescribe-diarization-engine:8006
SVC08_URL=http://voicescribe-export-service:8007

# Redis (pub/sub for job status)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=change_me_redis_password

# Inter-service auth
INTERNAL_SERVICE_TOKEN=change_me_internal_token

# Service
PORT=8004
LOG_LEVEL=INFO

# Circuit breaker
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# Retry
HTTP_RETRY_ATTEMPTS=3
HTTP_RETRY_BACKOFF_BASE=2
