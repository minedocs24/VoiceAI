# =========================
# Redis (obbligatorie)
# =========================
# Host Redis. Formato: hostname o IP.
# Obbligatoria. Default: redis
REDIS_HOST=redis
# Porta Redis. Formato: intero 1-65535.
# Obbligatoria. Default: 6379
REDIS_PORT=6379
# Numero database Redis (0-15). Usare DB dedicato per quota.
# Obbligatoria. Default: 2
REDIS_DB=2
# Password Redis per AUTH.
# Obbligatoria.
REDIS_PASSWORD=change_me_redis_password
# Timeout operazioni Redis in secondi.
# Opzionale. Default: 5
REDIS_TIMEOUT=5

# =========================
# PostgreSQL (obbligatorie)
# =========================
# URL SQLAlchemy completo per connessione async.
# Formato: postgresql+asyncpg://user:password@host:port/dbname
# Obbligatoria.
DATABASE_URL=postgresql+asyncpg://voicescribe_app:change_me_voicescribe_app@postgres:5432/voicescribe

# =========================
# Servizio
# =========================
# Porta su cui il servizio espone le API.
# Obbligatoria. Default: 8002
PORT=8002
# Livello di log: DEBUG, INFO, WARNING, ERROR.
# Opzionale. Default: INFO
LOG_LEVEL=INFO

# =========================
# Quota
# =========================
# Limite giornaliero trascrizioni per tenant Free Tier.
# Opzionale. Default: 2
FREE_TIER_DAILY_LIMIT=2

# =========================
# Sicurezza
# =========================
# Token per autenticazione inter-servizio (header X-Internal-Token).
# Obbligatoria. Deve coincidere con INTERNAL_SERVICE_TOKEN dell'infrastruttura.
INTERNAL_SERVICE_TOKEN=change_me_internal_token
