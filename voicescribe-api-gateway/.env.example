# VoiceScribe API Gateway - Environment variables
# Copy to .env and configure

# Upstream services (internal Docker hostnames)
SVC02_URL=http://voicescribe-file-ingestion:8001
SVC03_URL=http://voicescribe-quota-manager:8002

# Token for inter-service calls (X-Internal-Token)
INTERNAL_SERVICE_TOKEN=

# JWT for Free Tier sessions
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRES_HOURS=24
JWT_REFRESH_EXPIRES_DAYS=7

# PostgreSQL (tenant verification, API key hash, jobs read)
DATABASE_URL=postgresql+asyncpg://user:pass@postgres:5432/voicescribe

# Redis (rate limit, tenant cache, refresh tokens)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Server
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
LOG_LEVEL=INFO
SWAGGER_UI_ENABLED=true

# Timeouts
UPSTREAM_TIMEOUT_SECONDS=30
QUOTA_TIMEOUT_SECONDS=10
