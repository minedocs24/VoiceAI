# HuggingFace (obbligatorio per Pyannote)
HUGGINGFACE_TOKEN=
PYANNOTE_MODEL=pyannote/speaker-diarization-3.1

# GPU
CUDA_VISIBLE_DEVICES=0
HF_HOME=/models/pyannote

# Celery
CELERY_BROKER_URL=redis://:change_me_redis_password@redis:6379/0
CELERY_RESULT_BACKEND=redis://:change_me_redis_password@redis:6379/1
CELERY_QUEUE_NAME=gpu_tasks
CELERY_WORKER_CONCURRENCY=1

# Callbacks and security
SVC05_URL=http://voicescribe-job-orchestrator:8004
INTERNAL_SERVICE_TOKEN=change_me_internal_token

# Service
PORT=8006
LOG_LEVEL=INFO
DIARIZATION_TIMEOUT_SECONDS=600
