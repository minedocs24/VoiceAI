# Output
OUTPUT_BASE_PATH=/data/output
RAMDISK_PATH=/mnt/ramdisk
OUTPUT_TTL_DAYS=30

# Redis
REDIS_URL=redis://:change_me_redis_password@redis:6379/0

# PostgreSQL (per lettura stato job)
DATABASE_URL=postgresql://user:pass@postgres:5432/voicescribe

# Callbacks
SVC05_CALLBACK_URL=http://voicescribe-job-orchestrator:8004
INTERNAL_SERVICE_TOKEN=change_me_internal_token

# Service
PORT=8007
LOG_LEVEL=INFO

# Formati abilitati
ENABLE_TXT=true
ENABLE_SRT=true
ENABLE_JSON=true
ENABLE_DOCX=true
